---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 Page Not Found">
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-6 py-20">
    <div class="max-w-lg mx-auto text-center">
      <p class="text-accent font-medium text-sm uppercase tracking-wider mb-4">Page Not Found</p>
      <h1 class="font-serif text-7xl text-stone mb-4">404</h1>
      <p class="text-lg text-stone/70 mb-8">
        Unfortunately, the page you requested could not be found. This may be
        due to a misspelled URL or the page being removed.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-3 bg-primary text-cream font-medium rounded-lg hover:bg-primary-hover transition-colors duration-200"
      >
        Return Home
      </a>
    </div>
  </div>
</Layout>
