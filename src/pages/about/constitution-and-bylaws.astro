---
import Layout from "../../layouts/Layout.astro";
import ImageHeader from "../../components/ImageHeader.astro";
import constitutionHeader from "../../images/pages/constitution.jpg";
---

<Layout
  title="Constitution and Bylaws"
  description="Read the constitution and bylaws of Lone Rock Bible Church. Learn about our church governance, membership, and organizational structure."
>
  <ImageHeader
    image={constitutionHeader}
    alt="Historic document representing church constitution and governance guidelines"
    title="Constitution and Bylaws"
  />

  <div class="max-w-3xl mx-auto px-6 py-12">
    <p class="scroll-reveal text-center text-lg text-stone/80 mb-12">
      Our church constitution and bylaws outline the governance structure,
      doctrinal positions, membership requirements, and operational procedures
      of Lone Rock Bible Church. These documents provide important information
      about how our church is organized and operates according to biblical
      principles.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="scroll-reveal bg-sand/50 rounded-xl p-8 border border-sand text-center">
        <h2 class="font-serif text-2xl text-stone mb-3">Church Constitution</h2>
        <div class="w-10 h-0.5 bg-accent mx-auto mb-4"></div>
        <p class="text-stone/70 mb-6">
          The constitution includes our doctrinal statement, purpose,
          membership requirements, and governance structure.
        </p>
        <a
          href="/about/constitution"
          class="inline-flex items-center justify-center px-6 py-2.5 bg-primary text-cream font-medium rounded-lg hover:bg-primary-hover transition-colors duration-200"
        >
          View Constitution
        </a>
      </div>

      <div class="scroll-reveal stagger-1 bg-sand/50 rounded-xl p-8 border border-sand text-center">
        <h2 class="font-serif text-2xl text-stone mb-3">Church Bylaws</h2>
        <div class="w-10 h-0.5 bg-accent mx-auto mb-4"></div>
        <p class="text-stone/70 mb-6">
          The bylaws detail our leadership structure, financial policies,
          membership procedures, and church ministry operations.
        </p>
        <a
          href="/about/bylaws"
          class="inline-flex items-center justify-center px-6 py-2.5 bg-primary text-cream font-medium rounded-lg hover:bg-primary-hover transition-colors duration-200"
        >
          View Bylaws
        </a>
      </div>
    </div>
  </div>
</Layout>
