---
import ImageHeader from "../components/ImageHeader.astro";
import contactImage from "../images/pages/contact-us.jpg";
import Layout from "../layouts/Layout.astro";
const web3APIkey = import.meta.env.FORM_API_KEY;
---

<Layout
  title="Contact"
  description="Contact Lone Rock Bible Church in Stevensville, Montana. Find our address, phone number, email, and directions. We'd love to hear from you!"
>
  <ImageHeader
    title="Contact Us"
    image={contactImage}
    alt="Wooden mailboxes representing church communication and connection"
  />

  <div class="max-w-2xl mx-auto px-6 py-12">
    <div class="scroll-reveal bg-sand/50 rounded-xl p-8 border border-sand">
      <h2 class="font-serif text-2xl text-stone mb-2 text-center">Send Us a Message</h2>
      <p class="text-stone/60 text-sm text-center mb-8">
        We'd love to hear from you. Fill out the form below and we'll get back to you.
      </p>

      <form
        method="POST"
        id="form"
        novalidate
        class="space-y-5"
      >
        <input type="hidden" name="access_key" value={web3APIkey} />

        <div>
          <label for="name" class="block text-sm font-medium text-stone mb-1.5">Name</label>
          <input
            type="text"
            name="name"
            id="name"
            class="w-full px-4 py-2.5 bg-cream border border-sand rounded-lg text-stone focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
            required
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-stone mb-1.5">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            class="w-full px-4 py-2.5 bg-cream border border-sand rounded-lg text-stone focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
            required
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-stone mb-1.5">Message</label>
          <textarea
            rows="5"
            name="message"
            id="message"
            class="w-full px-4 py-2.5 bg-cream border border-sand rounded-lg text-stone focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-y"
            required></textarea>
        </div>

        <div>
          <div class="h-captcha" data-captcha="true"></div>
        </div>

        <button
          type="submit"
          class="w-full px-6 py-3 bg-primary text-cream font-medium rounded-lg hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-primary/50 transition-colors duration-200"
        >
          Send Message
        </button>

        <div id="result" class="mt-4 text-center text-sm"></div>
      </form>
    </div>
  </div>

  <script is:inline>
    const form = document.getElementById("form");
    const result = document.getElementById("result");

    form.addEventListener("submit", function (e) {
      const formData = new FormData(form);
      e.preventDefault();

      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      result.innerHTML = '<span class="text-stone/60">Sending...</span>';

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.innerHTML =
              '<span class="text-sage font-medium">Thanks for reaching out! We\'re looking forward to reading your message.</span>';
          } else {
            console.log(response);
            result.innerHTML =
              '<span class="text-primary">' + json.message + "</span>";
          }
        })
        .catch((error) => {
          console.log(error);
          result.innerHTML =
            '<span class="text-primary">Something went wrong. Please try again.</span>';
        })
        .then(function () {
          form.reset();
          setTimeout(() => {
            result.style.display = "none";
          }, 10000);
        });
    });
  </script>

  <!-- Required for hCaptcha -->
  <script is:inline src="https://web3forms.com/client/script.js" async defer></script>
</Layout>
