---
interface Props {
  name: string;
  field: string;
  email?: string;
  phone?: string;
  address?: string;
}
const { name, field, email, phone, address } = Astro.props;
---

<div class="scroll-reveal bg-sand/50 rounded-xl p-5 border border-sand hover:shadow-md transition-shadow duration-300">
  <h3 class="font-serif text-xl text-stone mb-1">{name}</h3>
  <p class="text-sm font-medium text-accent mb-3">
    Serving in: {field}
  </p>

  {email && (
    <p class="text-xs text-stone/60 mb-1">
      Email: <a href={`mailto:${email}`} class="text-primary hover:underline">{email}</a>
    </p>
  )}
  {phone && (
    <p class="text-xs text-stone/60 mb-1">{phone}</p>
  )}
  {address && (
    <p class="text-xs text-stone/60 mb-3">{address}</p>
  )}

  <div class="text-sm text-stone/80 leading-relaxed [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2">
    <slot />
  </div>
</div>
