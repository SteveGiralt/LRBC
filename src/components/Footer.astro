---
import SocialIcons from "./SocialIcons.astro";
---

<footer class="bg-stone text-cream/90">
  <div class="max-w-screen-xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Contact -->
      <div>
        <h3 class="font-serif text-xl text-cream mb-4">Contact Us</h3>
        <div class="space-y-1.5 text-sm text-cream/70">
          <p class="font-medium text-cream/90">Lone Rock Bible Church</p>
          <a
            href="https://www.google.com/maps/search/?api=1&query=Lone+Rock+Bible+Church+1142+Three+Mile+Creek+Rd+Stevensville+MT+59870"
            target="_blank"
            rel="noopener noreferrer"
            class="block text-cream/80 hover:text-cream transition-colors"
          >
            <p>1142 Three Mile Creek Rd</p>
            <p>Stevensville, MT 59870</p>
          </a>
          <p class="mt-3">
            <span class="text-cream font-medium">Phone:</span> 406.777.2592
          </p>
          <p>
            <span class="text-cream font-medium">Email:</span> info@lonerockbiblechurch.com
          </p>
        </div>
      </div>

      <!-- Schedule -->
      <div>
        <h3 class="font-serif text-xl text-cream mb-4">Weekly Schedule</h3>
        <div class="space-y-3 text-sm text-cream/70">
          <div>
            <p class="font-medium text-cream/90">Sunday Worship</p>
            <p>10:00 AM</p>
          </div>
          <div>
            <p class="font-medium text-cream/90">Kid's Sunday School</p>
            <p>10:00 AM</p>
          </div>
          <p class="italic text-cream/70 text-xs mt-2">Nursery available, Infant to 3 Years</p>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-serif text-xl text-cream mb-4">Quick Links</h3>
        <nav aria-label="Footer navigation">
          <ul class="space-y-2 text-sm text-cream/80">
            <li><a href="/" class="hover:text-cream transition-colors">Home</a></li>
            <li><a href="/about/beliefs" class="hover:text-cream transition-colors">Our Beliefs</a></li>
            <li><a href="/about/pastors" class="hover:text-cream transition-colors">Our Pastors</a></li>
            <li><a href="/about/missions" class="hover:text-cream transition-colors">Missionaries</a></li>
            <li><a href="/youth" class="hover:text-cream transition-colors">Youth Group</a></li>
            <li><a href="/visit" class="hover:text-cream transition-colors">Visit</a></li>
            <li><a href="/contact" class="hover:text-cream transition-colors">Contact</a></li>
          </ul>
        </nav>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="font-serif text-xl text-cream mb-4">Connect With Us</h3>
        <p class="text-sm text-cream/70 mb-4">
          Follow us for updates, sermons, and community news.
        </p>
        <SocialIcons class="text-cream/80" iconClass="w-7 h-7" />
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-cream/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-cream/60">
        &copy; {new Date().getFullYear()} Lone Rock Bible Church. All rights reserved.
      </p>
      <p class="text-xs text-cream/60 italic">
        Love God &middot; Love Others &middot; Impact the World
      </p>
    </div>
  </div>
</footer>
