---
import { Image } from "astro:assets";
import logo from "../images/logo.png";

const navMenu = [
  {
    label: "Home",
    link: "/",
  },
  {
    label: "About",
    subMenu: [
      { label: "Our Beliefs", link: "/about/beliefs" },
      { label: "Constitution and Bylaws", link: "/about/constitution-and-bylaws" },
      { label: "Our Pastors", link: "/about/pastors" },
      { label: "Our Missionaries", link: "/about/missions" },
    ],
  },
  { label: "Youth Group", link: "/youth" },
  { label: "Visit", link: "/visit" },
  { label: "Contact", link: "/contact" },
  {
    label: "Give",
    link: "http://onrealm.org/LoneRockBibleCh/Give",
    newTab: true,
  },
];

const currentPath = Astro.url.pathname;
---

<nav
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/95 backdrop-blur-md shadow-sm"
  id="main-nav"
  transition:persist
>
  <div class="max-w-screen-xl flex items-center justify-between mx-auto px-4 py-3">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <Image src={logo} alt="LRBC Logo" class="h-10 w-auto" />
      <span class="hidden md:block font-serif text-xl text-stone group-hover:text-primary transition-colors">
        Lone Rock Bible Church
      </span>
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-1 font-sans text-sm font-medium">
      {navMenu.map((item) => (
        <li class="relative group">
          {item.subMenu ? (
            <>
              <button
                class={`flex items-center gap-1 px-3 py-2 rounded-lg transition-colors duration-200 hover:bg-sand hover:text-primary ${
                  currentPath.startsWith("/about") ? "text-primary" : "text-stone"
                }`}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul class="absolute top-full left-0 mt-1 w-56 bg-white rounded-lg shadow-lg border border-sand opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-1 group-hover:translate-y-0 py-2">
                {item.subMenu.map((sub) => (
                  <li>
                    <a
                      href={sub.link}
                      class={`block px-4 py-2.5 text-sm transition-colors hover:bg-sand hover:text-primary ${
                        currentPath === sub.link ? "text-primary font-semibold" : "text-stone"
                      }`}
                    >
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a
              href={item.link}
              target={item.newTab ? "_blank" : "_self"}
              rel={item.newTab ? "noopener noreferrer" : undefined}
              class={`relative px-3 py-2 rounded-lg transition-colors duration-200 hover:bg-sand hover:text-primary ${
                currentPath === item.link ? "text-primary" : "text-stone"
              }`}
            >
              {item.label}
              {currentPath === item.link && (
                <span class="absolute bottom-0 left-3 right-3 h-0.5 bg-primary rounded-full" />
              )}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-sand transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="w-5 h-5 text-stone" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="w-5 h-5 text-stone hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-drawer"
    class="md:hidden fixed inset-0 top-[64px] bg-white transform translate-x-full transition-transform duration-300 ease-in-out z-40 overflow-y-auto"
  >
    <ul class="px-6 py-4 space-y-1 font-sans">
      {navMenu.map((item) => (
        <li>
          {item.subMenu ? (
            <div class="mobile-dropdown">
              <button
                class="flex items-center justify-between w-full px-3 py-3 rounded-lg text-stone hover:bg-sand hover:text-primary transition-colors font-medium"
                aria-expanded="false"
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform duration-200 dropdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <ul class="hidden pl-4 space-y-1 mt-1 dropdown-items">
                {item.subMenu.map((sub) => (
                  <li>
                    <a
                      href={sub.link}
                      class={`block px-3 py-2.5 rounded-lg text-sm transition-colors hover:bg-sand hover:text-primary ${
                        currentPath === sub.link ? "text-primary font-semibold" : "text-stone/80"
                      }`}
                    >
                      {sub.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ) : (
            <a
              href={item.link}
              target={item.newTab ? "_blank" : "_self"}
              rel={item.newTab ? "noopener noreferrer" : undefined}
              class={`block px-3 py-3 rounded-lg font-medium transition-colors hover:bg-sand hover:text-primary ${
                currentPath === item.link ? "text-primary bg-sand/50" : "text-stone"
              }`}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="h-[64px]"></div>

<script>
  function initNavbar() {
    const menuBtn = document.getElementById("mobile-menu-btn");
    const drawer = document.getElementById("mobile-drawer");
    const iconOpen = document.getElementById("menu-icon-open");
    const iconClose = document.getElementById("menu-icon-close");
    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      drawer?.classList.toggle("translate-x-full", !isOpen);
      drawer?.classList.toggle("translate-x-0", isOpen);
      iconOpen?.classList.toggle("hidden", isOpen);
      iconClose?.classList.toggle("hidden", !isOpen);
      menuBtn?.setAttribute("aria-expanded", String(isOpen));
      document.body.style.overflow = isOpen ? "hidden" : "";
    }

    function closeMenu() {
      if (isOpen) {
        isOpen = false;
        drawer?.classList.add("translate-x-full");
        drawer?.classList.remove("translate-x-0");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        menuBtn?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }
    }

    menuBtn?.addEventListener("click", toggleMenu);

    // Close menu when clicking a link
    drawer?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Mobile dropdown toggles
    document.querySelectorAll(".mobile-dropdown > button").forEach((btn) => {
      btn.addEventListener("click", () => {
        const items = btn.nextElementSibling;
        const chevron = btn.querySelector(".dropdown-chevron");
        const expanded = btn.getAttribute("aria-expanded") === "true";
        btn.setAttribute("aria-expanded", String(!expanded));
        items?.classList.toggle("hidden");
        chevron?.classList.toggle("rotate-180");
      });
    });

    // Scroll-aware navbar
    const nav = document.getElementById("main-nav");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 100) {
        nav?.classList.add("shadow-md");
      } else {
        nav?.classList.remove("shadow-md");
      }
    }, { passive: true });
  }

  initNavbar();
  document.addEventListener("astro:after-swap", initNavbar);
</script>
