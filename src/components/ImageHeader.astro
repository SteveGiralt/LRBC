---
import { Image } from "astro:assets";
interface Props {
  image: ImageMetadata;
  alt?: string;
  title: string;
}
const { image, alt, title } = Astro.props;
---

<div class="relative w-full h-72 md:h-80 lg:h-96 overflow-hidden">
  <Image
    src={image}
    alt={alt ?? title}
    class="w-full h-full object-cover"
    loading="eager"
    widths={[640, 1024, 1440, 1920]}
    sizes="100vw"
  />
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-stone/70 via-stone/20 to-transparent"></div>

  <!-- Title -->
  <div class="absolute inset-0 flex items-end justify-center pb-10 px-6">
    <h1 class="font-serif text-3xl md:text-5xl text-white text-center drop-shadow-lg">
      {title}
    </h1>
  </div>
</div>
