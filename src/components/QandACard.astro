---
interface Props {
  q: string;
}
const { q } = Astro.props;
---

<div class="scroll-reveal max-w-3xl mx-auto my-8 px-6">
  <div class="border-l-4 border-accent pl-6 py-2">
    <h3 class="font-serif text-2xl text-stone mb-3">{q}</h3>
    <div class="text-stone/80 leading-relaxed space-y-3 [&_ul]:ml-6 [&_ul]:space-y-2 [&_li]:leading-relaxed">
      <slot />
    </div>
  </div>
</div>
