---

<div class="bg-sand/50 rounded-xl p-6 border border-sand">
  <h2 class="font-serif text-2xl text-stone mb-4">Watch Online</h2>
  <div class="w-10 h-0.5 bg-accent mb-5"></div>

  <div class="space-y-4">
    <div class="border-l-3 border-primary pl-4 py-2">
      <p class="text-xs font-medium text-accent uppercase tracking-wide">Current Sermon Series</p>
      <h3 class="font-serif text-lg text-stone mt-1">
        Colossians &mdash; Complete in Christ
      </h3>
    </div>

    <div class="border-l-3 border-primary pl-4 py-2">
      <p class="text-xs font-medium text-accent uppercase tracking-wide">Watch Live</p>
      <p class="font-serif text-lg text-stone mt-1">Every Sunday at 10:00 AM MT</p>
      <div class="flex items-center gap-3 mt-3">
        <a
          href="http://www.facebook.com/lrbcmt"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#1877F2] text-white text-sm font-medium hover:bg-[#1565C0] transition-colors"
          aria-label="Watch on Facebook"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Facebook
        </a>
        <a
          href="https://www.youtube.com/@LoneRockBibleChurch"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#FF0000] text-white text-sm font-medium hover:bg-[#CC0000] transition-colors"
          aria-label="Watch on YouTube"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          YouTube
        </a>
      </div>
    </div>
  </div>
</div>
