---
interface Props {
  name: string;
}
const { name } = Astro.props;
---

<div class="scroll-reveal bg-sand/50 rounded-xl p-6 md:p-8 border border-sand">
  <h3 class="font-serif text-2xl text-stone mb-4">{name}</h3>
  <div class="w-10 h-0.5 bg-accent mb-4"></div>
  <div class="text-stone/80 leading-relaxed space-y-3 [&_p]:mb-3 [&_ol]:ml-6 [&_ol]:space-y-3 [&_ul]:ml-6 [&_ul]:space-y-2 [&_li]:leading-relaxed [&_strong]:text-stone [&_h3]:font-serif [&_h3]:text-xl [&_h3]:text-stone [&_h3]:mt-6 [&_h3]:mb-2 [&_h4]:font-sans [&_h4]:font-bold [&_h4]:text-stone [&_h4]:mt-4 [&_h4]:mb-2 [&_h5]:font-sans [&_h5]:font-semibold [&_h5]:text-stone/90 [&_h5]:mt-3 [&_h5]:mb-2 [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2">
    <slot />
  </div>
</div>
