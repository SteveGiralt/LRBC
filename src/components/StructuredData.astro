---
const {
  title,
  description = "Serving the Lone Rock and Stevensville areas of Montana. Purposing to Love God, Love Others, Impact the World",
} = Astro.props;

const pathname = Astro.url.pathname;
const pageUrl = `https://www.lonerockbiblechurch.com${pathname}`;
const fullTitle = title ? `${title} | Lone Rock Bible Church` : "Lone Rock Bible Church";
const isAboutPage = pathname.startsWith("/about/");

const graph: Record<string, unknown>[] = [
  {
    "@type": "Church",
    "@id": "https://www.lonerockbiblechurch.com/#organization",
    name: "Lone Rock Bible Church",
    alternateName: "LRBC",
    url: "https://www.lonerockbiblechurch.com",
    logo: {
      "@type": "ImageObject",
      url: "https://www.lonerockbiblechurch.com/images/meta-image.png",
    },
    description:
      "Serving the Lone Rock and Stevensville areas of Montana. Purposing to Love God, Love Others, Impact the World",
    address: {
      "@type": "PostalAddress",
      streetAddress: "1142 Three Mile Creek Rd",
      addressLocality: "Stevensville",
      addressRegion: "MT",
      postalCode: "59870",
      addressCountry: "US",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: 46.4902,
      longitude: -114.0927,
    },
    telephone: "+1-406-777-2592",
    email: "info@lonerockbiblechurch.com",
    sameAs: [
      "https://www.facebook.com/lrbcmt",
      "https://www.youtube.com/@LoneRockBibleChurch",
    ],
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: "Sunday",
        opens: "10:00",
        closes: "11:30",
        description: "Sunday Worship Service",
      },
    ],
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Church Services",
      itemListElement: [
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Sunday Worship Service",
            description:
              "Weekly worship service with music and biblical teaching",
            serviceType: "Religious Service",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Children's Ministry",
            description:
              "Nursery (infant-3 years) and Kids Sunday School (ages 4-11)",
            serviceType: "Children's Ministry",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Youth Group",
            description:
              "Wednesday night youth group for junior high and high school students",
            serviceType: "Youth Ministry",
          },
        },
      ],
    },
  },
  {
    "@type": "WebSite",
    "@id": "https://www.lonerockbiblechurch.com/#website",
    url: "https://www.lonerockbiblechurch.com",
    name: "Lone Rock Bible Church",
    description:
      "Serving the Lone Rock and Stevensville areas of Montana. Purposing to Love God, Love Others, Impact the World",
    publisher: {
      "@id": "https://www.lonerockbiblechurch.com/#organization",
    },
    inLanguage: "en-US",
  },
  {
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    url: pageUrl,
    name: fullTitle,
    isPartOf: {
      "@id": "https://www.lonerockbiblechurch.com/#website",
    },
    about: {
      "@id": "https://www.lonerockbiblechurch.com/#organization",
    },
    description,
    inLanguage: "en-US",
  },
];

if (isAboutPage) {
  graph.push({
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: "https://www.lonerockbiblechurch.com",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: title || "About",
        item: pageUrl,
      },
    ],
  });
}
---

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": graph,
  })}
/>
