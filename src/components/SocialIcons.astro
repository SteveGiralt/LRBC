---
interface Props {
  class?: string;
  iconClass?: string;
}
const { class: className = "", iconClass = "w-6 h-6" } = Astro.props;
---

<div class={`flex items-center gap-4 ${className}`}>
  <a
    href="http://www.facebook.com/lrbcmt"
    class="text-current hover:text-accent transition-colors duration-200"
    aria-label="Visit our Facebook page"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="sr-only">Visit our Facebook page</span>
    <svg class={iconClass} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
    </svg>
  </a>

  <a
    href="https://www.youtube.com/@LoneRockBibleChurch"
    class="text-current hover:text-accent transition-colors duration-200"
    aria-label="Watch us on YouTube"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="sr-only">Watch us on YouTube</span>
    <svg class={iconClass} fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
    </svg>
  </a>

  <a
    href="/contact"
    class="text-current hover:text-accent transition-colors duration-200"
    aria-label="Contact us"
  >
    <span class="sr-only">Contact us</span>
    <svg class={iconClass} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
    </svg>
  </a>
</div>
