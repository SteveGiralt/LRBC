---
import { Image } from "astro:assets";

interface Props {
  name: string;
  image: ImageMetadata;
  title?: string;
  quote?: string;
  email?: string;
}
const { name, image, title = "", quote = "", email } = Astro.props;
---

<div class="scroll-reveal group bg-sand/50 rounded-xl overflow-hidden border border-sand hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <!-- Photo -->
  <div class="aspect-[4/3] overflow-hidden">
    <Image
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      src={image}
      alt={`Image of ${name}`}
      quality={80}
      widths={[300, 450, 600]}
      sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
    />
  </div>

  <!-- Info -->
  <div class="p-5">
    <h3 class="font-serif text-xl text-stone mb-1">{name}</h3>
    <div class="w-8 h-0.5 bg-accent mb-2"></div>
    {title && (
      <p class="text-sm font-medium text-primary mb-2">{title}</p>
    )}
    <div class="text-sm text-stone/70 leading-relaxed">
      <slot />
    </div>
    {quote && (
      <p class="italic text-sm text-stone/60 mt-3 border-l-2 border-accent/40 pl-3">{quote}</p>
    )}
  </div>
</div>
